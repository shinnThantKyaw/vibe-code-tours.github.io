---
interface Props {
  name: string;
  github: string;
  role: "builder" | "mentor" | "instructor";
  skills?: string[];
  repo?: string;
  x?: string;
  linkedin?: string;
  website?: string;
}

const { name, github, role, skills, repo, x, linkedin, website } = Astro.props;

const avatar = `https://github.com/${github}.png?size=160`;
const roleClass =
  role === "instructor" ? "tier-c" : role === "mentor" ? "tier-b" : "tier-a";

// Normalize a handle-or-URL into a full URL.
const url = (val: string | undefined, base: string) =>
  !val
    ? undefined
    : val.startsWith("http")
      ? val
      : base + val.replace(/^@/, "");

const links = [
  { label: "GitHub", href: `https://github.com/${github}`, show: true },
  { label: "Repo", href: repo, show: !!repo },
  { label: "X", href: url(x, "https://x.com/"), show: !!x },
  {
    label: "LinkedIn",
    href: url(linkedin, "https://linkedin.com/in/"),
    show: !!linkedin,
  },
  { label: "Web", href: website, show: !!website },
].filter((l) => l.show);
---

<article class="card flex flex-col">
  <div class="flex items-center gap-3">
    <img
      src={avatar}
      alt={`${name} avatar`}
      width="48"
      height="48"
      loading="lazy"
      class="h-12 w-12 shrink-0 rounded-full border border-accent-500/30 bg-surface-elevated object-cover"
    />
    <div class="min-w-0">
      <p class="truncate font-bold text-white">{name}</p>
      <a
        href={`https://github.com/${github}`}
        target="_blank"
        rel="noopener"
        class="font-mono text-xs text-gray-500 no-underline hover:text-accent-500"
      >
        @{github}
      </a>
    </div>
    <span class:list={["tier", roleClass, "ml-auto shrink-0"]} title={role}>
      {role[0].toUpperCase()}
    </span>
  </div>

  {
    skills && skills.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {skills.map((skill) => (
          <span class="rounded-full border border-white/10 bg-white/5 px-2 py-0.5 font-mono text-[10px] font-semibold text-gray-400">
            {skill}
          </span>
        ))}
      </div>
    )
  }

  <div class="prose-builder mt-3 line-clamp-3 text-sm text-gray-400">
    <slot />
  </div>

  <div
    class="mt-4 flex flex-wrap gap-x-4 gap-y-1 border-t border-white/5 pt-3 text-xs font-semibold"
  >
    {
      links.map((l) => (
        <a
          href={l.href}
          target="_blank"
          rel="noopener"
          class="text-gray-500 no-underline hover:text-accent-500"
        >
          {l.label}
        </a>
      ))
    }
  </div>
</article>

<style>
  .prose-builder :global(p) {
    margin: 0;
  }
</style>
